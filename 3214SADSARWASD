	local function openDropdownPanel(title, options, dropFunc, multi)
		dpTitle.Text = title
		dpSearch.Text = ""
		activeDropRef = dropFunc

		for _, c in dpScroll:GetChildren() do
			if c:IsA("Frame") then c:Destroy() end
		end

		for i, opt in ipairs(options) do
			local label, value
			if typeof(opt) == "table" and opt.Label then
				label = tostring(opt.Label)
				value = opt.Value
			else
				label = tostring(opt)
				value = opt
			end

			local of = Instance.new("Frame")
			of.Name = "Opt"
			of.Size = UDim2.new(1, 0, 0, 30)
			of.BackgroundColor3 = COL.card
			of.BackgroundTransparency = 1
			of.BorderSizePixel = 0
			of.LayoutOrder = i
			of.ZIndex = 83
			of.Parent = dpScroll
			local ofCorner = Instance.new("UICorner", of)
			ofCorner.CornerRadius = UDim.new(0, 7)
			of:SetAttribute("Val", value)

			local ob = Instance.new("TextButton")
			ob.Text = ""
			ob.Size = UDim2.new(1, 0, 1, 0)
			ob.BackgroundTransparency = 1
			ob.ZIndex = 84
			ob.Parent = of

			local ol = Instance.new("TextLabel")
			ol.Name = "Label"
			ol.Font = Enum.Font.Gotham
			ol.Text = label
			ol.TextSize = 12
			ol.TextColor3 = COL.textDim
			ol.TextXAlignment = Enum.TextXAlignment.Left
			ol.BackgroundTransparency = 1
			ol.Position = UDim2.new(0, 10, 0, 0)
			ol.Size = UDim2.new(1, -32, 1, 0)
			ol.ZIndex = 83
			ol.Parent = of

			local ck = Instance.new("Frame")
			ck.Name = "Check"
			ck.AnchorPoint = Vector2.new(1, 0.5)
			ck.Position = UDim2.new(1, -8, 0.5, 0)
			ck.Size = UDim2.new(0, 8, 0, 8)
			ck.BackgroundColor3 = Accent
			ck.BorderSizePixel = 0
			ck.ZIndex = 83
			ck.Visible = false
			ck.Parent = of
			local ckCorner = Instance.new("UICorner", ck)
			ckCorner.CornerRadius = UDim.new(1, 0)

			local sel = multi and (table.find(dropFunc.Value, value) ~= nil) or (dropFunc.Value == value)
			ck.Visible = sel
			of.BackgroundTransparency = sel and 0.4 or 1
			if sel then ol.TextColor3 = COL.text end

			ob.MouseEnter:Connect(function()
				TweenService:Create(of, TWEEN_SNAP, { BackgroundTransparency = sel and 0.3 or 0.6 }):Play()
			end)
			ob.MouseLeave:Connect(function()
				local isSel2 = multi and (table.find(dropFunc.Value, value) ~= nil) or (dropFunc.Value == value)
				TweenService:Create(of, TWEEN_SNAP, { BackgroundTransparency = isSel2 and 0.4 or 1 }):Play()
			end)

			ob.MouseButton1Click:Connect(function()
				if multi then
					local idx2 = table.find(dropFunc.Value, value)
					if idx2 then table.remove(dropFunc.Value, idx2) else table.insert(dropFunc.Value, value) end
				else
					dropFunc.Value = value
				end
				for _, cf in dpScroll:GetChildren() do
					if cf:IsA("Frame") and cf:FindFirstChild("Check") then
						local cv = cf:GetAttribute("Val")
						local isSel = multi and (table.find(dropFunc.Value, cv) ~= nil) or (dropFunc.Value == cv)
						cf.Check.Visible = isSel
						TweenService:Create(cf, TWEEN_FAST, { BackgroundTransparency = isSel and 0.4 or 1 }):Play()
						if cf:FindFirstChild("Label") then
							TweenService:Create(cf.Label, TWEEN_FAST, { TextColor3 = isSel and COL.text or COL.textDim }):Play()
						end
					end
				end
				dropFunc:_apply()
				if not multi then closeDropdown() end
			end)
		end

