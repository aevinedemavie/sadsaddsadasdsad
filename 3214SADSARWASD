				end

				recalcHeight()
				frLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(recalcHeight)

				local F = {}
				function F:SetTitle(val)
					val = val or ""; cfg.Title = val; titleLbl.Text = val; titleLbl.Visible = val ~= ""; recalcHeight()
				end
				function F:SetContent(val)
					val = val or ""; cfg.Content = val; contentLbl.Text = val; contentLbl.Visible = val ~= ""; recalcHeight()
				end

				CountItem += 1
				return F
			end

			function Items:AddDivider()
				local line = Instance.new("Frame")
				line.Size = UDim2.new(1, -24, 0, 1)
				line.Position = UDim2.new(0, 12, 0, 0)
				line.BackgroundColor3 = COL.borderGlow
				line.BackgroundTransparency = 0.78
				line.BorderSizePixel = 0
				line.LayoutOrder = CountItem
				line.Parent = ItemHolder
				local corner = Instance.new("UICorner", line)
				corner.CornerRadius = UDim.new(0, 1)
				CountItem += 1
			end

			function Items:AddSubSection(title)
				title = title or "Sub Section"
				local sub = Instance.new("Frame")
				sub.Size = UDim2.new(1, 0, 0, 22)
				sub.BackgroundTransparency = 1
				sub.LayoutOrder = CountItem
				sub.Parent = ItemHolder

				local lineL = Instance.new("Frame")
				lineL.Size = UDim2.new(0, 20, 0, 1)
				lineL.Position = UDim2.new(0, 0, 0.5, 0)
				lineL.BackgroundColor3 = COL.borderGlow
				lineL.BackgroundTransparency = 0.6
				lineL.BorderSizePixel = 0
				lineL.Parent = sub

				local ll = Instance.new("TextLabel")
				ll.Font = Enum.Font.GothamBold
				ll.Text = string.upper(title)
				ll.TextSize = 9
				ll.TextColor3 = COL.textMuted
				ll.TextXAlignment = Enum.TextXAlignment.Center
				ll.BackgroundTransparency = 1
				ll.Position = UDim2.new(0, 24, 0, 4)
				ll.Size = UDim2.new(1, -50, 0, 14)
				ll.Parent = sub

				local lineR = Instance.new("Frame")
				lineR.Size = UDim2.new(0, 20, 0, 1)
				lineR.AnchorPoint = Vector2.new(1, 0.5)
				lineR.Position = UDim2.new(1, 0, 0.5, 0)
				lineR.BackgroundColor3 = COL.borderGlow
				lineR.BackgroundTransparency = 0.6
				lineR.BorderSizePixel = 0
				lineR.Parent = sub

				CountItem += 1
				return sub
			end

			function Items:AddButton(cfg)
				cfg = cfg or {}
				cfg.Title       = cfg.Title       or "Button"
				cfg.Callback    = cfg.Callback    or function() end
				cfg.SubTitle    = cfg.SubTitle    or nil
				cfg.SubCallback = cfg.SubCallback or function() end

				local fr = Instance.new("Frame")
				fr.Size = UDim2.new(1, 0, 0, 36)
				fr.BackgroundColor3 = COL.card
				fr.BackgroundTransparency = 0.35
				fr.BorderSizePixel = 0
				fr.LayoutOrder = CountItem
				fr.Parent = ItemHolder
				local frCorner = Instance.new("UICorner", fr)
				frCorner.CornerRadius = UDim.new(0, 9)
				-- no card stroke

				local function makeBtn(txt, posX, sizeX)
					local b = Instance.new("TextButton")
					b.Font = Enum.Font.GothamBold
					b.Text = txt
					b.TextSize = 11
					b.TextColor3 = COL.textDim
					b.BackgroundColor3 = COL.btnBg
					b.BackgroundTransparency = 0.15
					b.BorderSizePixel = 0
					b.AutoButtonColor = false
					b.Size = UDim2.new(sizeX, -5, 0, 28)
					b.Position = UDim2.new(posX, 4, 0, 4)
					b.Parent = fr
					local bCorner = Instance.new("UICorner", b)
					bCorner.CornerRadius = UDim.new(0, 7)
					addGlowStroke(b, COL.borderLight, 1, 0.7)
					addGradient(b, Color3.fromRGB(25, 35, 75), Color3.fromRGB(12, 18, 40), 160)

					b.MouseEnter:Connect(function()
						TweenService:Create(b, TWEEN_FAST, { BackgroundColor3 = COL.btnHover, BackgroundTransparency = 0, TextColor3 = COL.text }):Play()
						local stroke = b:FindFirstChildOfClass("UIStroke")
						if stroke then TweenService:Create(stroke, TWEEN_FAST, { Color = Accent, Transparency = 0.5 }):Play() end
					end)
					b.MouseLeave:Connect(function()
						TweenService:Create(b, TWEEN_FAST, { BackgroundColor3 = COL.btnBg, BackgroundTransparency = 0.15, TextColor3 = COL.textDim }):Play()
						local stroke = b:FindFirstChildOfClass("UIStroke")
						if stroke then TweenService:Create(stroke, TWEEN_FAST, { Color = COL.borderLight, Transparency = 0.7 }):Play() end
					end)
					b.MouseButton1Down:Connect(function()
						TweenService:Create(b, TWEEN_SNAP, { BackgroundColor3 = Accent, BackgroundTransparency = 0.3, TextColor3 = Color3.new(1,1,1) }):Play()
					end)
					b.MouseButton1Up:Connect(function()
						TweenService:Create(b, TWEEN_FAST, { BackgroundColor3 = COL.btnHover, BackgroundTransparency = 0, TextColor3 = COL.text }):Play()
					end)
					return b
				end

				if cfg.SubTitle then
					local mb = makeBtn(cfg.Title, 0, 0.5)
					local sb = makeBtn(cfg.SubTitle, 0.5, 0.5)
					mb.MouseButton1Click:Connect(function() pcall(cfg.Callback) end)
					sb.MouseButton1Click:Connect(function() pcall(cfg.SubCallback) end)
				else
					local mb = makeBtn(cfg.Title, 0, 1)
					mb.MouseButton1Click:Connect(function() pcall(cfg.Callback) end)
				end

				CountItem += 1
			end

			function Items:AddSlider(cfg)
				cfg = cfg or {}
				cfg.Title     = cfg.Title     or "Slider"
				cfg.Increment = cfg.Increment or 1
				cfg.Min       = cfg.Min       or 0
				cfg.Max       = cfg.Max       or 100
				cfg.Default   = cfg.Default   or 50
				cfg.Callback  = cfg.Callback  or function() end

				local ck = "Slider_" .. cfg.Title
				if ConfigData[ck] ~= nil then cfg.Default = ConfigData[ck] end
				local F = { Value = cfg.Default }

				local fr = Instance.new("Frame")
				fr.Size = UDim2.new(1, 0, 0, 40)
				fr.BackgroundColor3 = COL.card
				fr.BackgroundTransparency = 0.35
				fr.BorderSizePixel = 0
				fr.LayoutOrder = CountItem
				fr.Parent = ItemHolder
				local frCorner = Instance.new("UICorner", fr)
				frCorner.CornerRadius = UDim.new(0, 9)
				-- no card stroke

				local stl = Instance.new("TextLabel")
				stl.Font = Enum.Font.GothamBold
				stl.Text = cfg.Title
				stl.TextSize = 12
				stl.TextColor3 = COL.text
				stl.TextXAlignment = Enum.TextXAlignment.Left
				stl.BackgroundTransparency = 1
				stl.Position = UDim2.new(0, 12, 0, 5)
				stl.Size = UDim2.new(0.55, 0, 0, 14)
				stl.Parent = fr

				local vl = Instance.new("TextLabel")
				vl.Font = Enum.Font.GothamBold
				vl.Text = tostring(cfg.Default)
				vl.TextSize = 11
				vl.TextColor3 = Accent
				vl.TextXAlignment = Enum.TextXAlignment.Right
				vl.BackgroundTransparency = 1
				vl.AnchorPoint = Vector2.new(1, 0)
				vl.Position = UDim2.new(1, -12, 0, 5)
				vl.Size = UDim2.new(0.3, 0, 0, 14)
				vl.Parent = fr

				local trkBg = Instance.new("Frame")
				trkBg.Position = UDim2.new(0, 12, 0, 28)
				trkBg.Size = UDim2.new(1, -24, 0, 4)
				trkBg.BackgroundColor3 = COL.trackBg
				trkBg.BackgroundTransparency = 0.2
				trkBg.BorderSizePixel = 0
				trkBg.Parent = fr
				local trkBgCorner = Instance.new("UICorner", trkBg)
				trkBgCorner.CornerRadius = UDim.new(1, 0)

				local trk = trkBg

				local fill = Instance.new("Frame")
				fill.Size = UDim2.new(0.5, 0, 1, 0)
				fill.BackgroundColor3 = Accent
				fill.BackgroundTransparency = 0
				fill.BorderSizePixel = 0
				fill.Parent = trk
				local fillCorner = Instance.new("UICorner", fill)
				fillCorner.CornerRadius = UDim.new(1, 0)
				addGradient(fill, Accent, Color3.fromRGB(
					math.floor(Accent.R * 255 * 0.5),
					math.floor(Accent.G * 255 * 0.5),
					math.floor(Accent.B * 255 * 0.5)
				), 0)

				local knob = Instance.new("Frame")
				knob.AnchorPoint = Vector2.new(0.5, 0.5)
				knob.Position = UDim2.new(1, 0, 0.5, 0)
				knob.Size = UDim2.new(0, 12, 0, 12)
				knob.BackgroundColor3 = Color3.new(1, 1, 1)
				knob.BorderSizePixel = 0
				knob.ZIndex = 3
				knob.Parent = fill
				local knobCorner = Instance.new("UICorner", knob)
				knobCorner.CornerRadius = UDim.new(1, 0)
				addGlowStroke(knob, Accent, 2, 0.4)

				local dr = false
				local function rnd(n, f) return math.floor(n / f + 0.5) * f end

				function F:Set(val)
					val = math.clamp(rnd(val, cfg.Increment), cfg.Min, cfg.Max)
					F.Value = val
					vl.Text = tostring(val)
					local pct = (val - cfg.Min) / (cfg.Max - cfg.Min)
					TweenService:Create(fill, TWEEN_SMOOTH, { Size = UDim2.new(pct, 0, 1, 0) }):Play()
					ConfigData[ck] = val
					pcall(cfg.Callback, val)
				end

				trk.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dr = true
						TweenService:Create(knob, TWEEN_FAST, { Size = UDim2.new(0, 14, 0, 14) }):Play()
						local function upd(inp)
							local rel = (inp.Position.X - trk.AbsolutePosition.X) / trk.AbsoluteSize.X
							rel = math.clamp(rel, 0, 1)
							F:Set(cfg.Min + (cfg.Max - cfg.Min) * rel)
						end
						upd(input)
						local con
						con = input.Changed:Connect(function()
							if input.UserInputState == Enum.UserInputState.End then
								dr = false
								TweenService:Create(knob, TWEEN_FAST, { Size = UDim2.new(0, 12, 0, 12) }):Play()
								con:Disconnect()
							end
						end)
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if dr and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						local rel = (input.Position.X - trk.AbsolutePosition.X) / trk.AbsoluteSize.X
						rel = math.clamp(rel, 0, 1)
						F:Set(cfg.Min + (cfg.Max - cfg.Min) * rel)
					end
				end)

				F:Set(F.Value)
				CountItem += 1
				Elements[ck] = F
				return F
			end

			CountSection += 1
			return Items
		end

		CountTab += 1
		return Sections
	end

	function GuiFunc:AddConfigSection()
		local ConfigTab = Tabs:AddTab({Name = "Settings", Icon = "settings"})
		local ConfigSection = ConfigTab:AddSection("Configuration", true)

		local configDropdown = ConfigSection:AddDropdown({
			Title = "Select Config",
			Options = GetConfigList(),
			Callback = function() end
		})

		local configNameInput = ConfigSection:AddInput({
			Title = "Config Name",
			Default = "",
			Callback = function() end
		})

		ConfigSection:AddButton({
			Title = "Save Config",
			Callback = function()
				local name = configNameInput.Value
				if SaveConfigAs(name) then
					Notify("Config saved: " .. name, 2, Color3.fromRGB(80, 200, 120))
					configDropdown:SetValues(GetConfigList(), name)
				else
					Notify("Failed to save config", 2, Color3.fromRGB(220, 85, 85))
				end
			end,
			SubTitle = "Load Config",
			SubCallback = function()
				local name = configDropdown.Value
				if LoadConfig(name) then
					Notify("Config loaded: " .. name, 2, Color3.fromRGB(80, 200, 120))
				else
					Notify("Failed to load config", 2, Color3.fromRGB(220, 85, 85))
				end
			end
		})

		ConfigSection:AddButton({
			Title = "Delete Config",
			Callback = function()
				local name = configDropdown.Value
				if DeleteConfig(name) then
					Notify("Config deleted: " .. name, 2, Color3.fromRGB(220, 200, 85))
					configDropdown:SetValues(GetConfigList(), nil)
				else
					Notify("Failed to delete config", 2, Color3.fromRGB(220, 85, 85))
				end
			end,
			SubTitle = "Refresh List",
			SubCallback = function()
				configDropdown:SetValues(GetConfigList(), configDropdown.Value)
				Notify("Config list refreshed", 1.5, Accent)
			end
		})

		local AutoloadSection = ConfigTab:AddSection("Autoload")
		local autoloadToggle

		autoloadToggle = AutoloadSection:AddToggle({
			Title = "Enable Autoload",
			Default = GetAutoload() ~= nil,
			Callback = function(val)
				if val then
					local name = configDropdown.Value
					if name and name ~= "" then
						SetAutoload(name)
						Notify("Autoload set: " .. name, 2, Accent)
					else
						if autoloadToggle then autoloadToggle:Set(false) end
						Notify("Select a config first", 2, Color3.fromRGB(220, 85, 85))
					end
				else
					ClearAutoload()
					Notify("Autoload cleared", 2, Color3.fromRGB(220, 200, 85))
				end
			end
		})
	end

	return GuiFunc, Tabs
end

return Orion
