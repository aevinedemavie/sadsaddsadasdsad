	-- ── Drag ──────────────────────────────────────────────────────────────────
	local function MakeDraggable(handle, frame)
		local drag, start, origin
		handle.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
				drag = true; start = i.Position; origin = frame.Position
				i.Changed:Connect(function()
					if i.UserInputState == Enum.UserInputState.End then drag = false end
				end)
			end
		end)
		local lastIn
		handle.InputChanged:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseMovement
			or i.UserInputType == Enum.UserInputType.Touch then lastIn = i end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if i == lastIn and drag then
				local d = i.Position - start
				frame.Position = UDim2.new(
					origin.X.Scale, origin.X.Offset + d.X,
					origin.Y.Scale, origin.Y.Offset + d.Y
				)
			end
		end)
	end

	-- ── Resize ────────────────────────────────────────────────────────────────
	local function MakeResizable(frame, mnW, mnH, mxW, mxH)
		local rh = Instance.new("Frame", frame)
		rh.AnchorPoint = Vector2.new(1,1)
		rh.Position = UDim2.new(1,0,1,0)
		rh.Size = UDim2.new(0,14,0,14)
		rh.BackgroundTransparency = 1
		rh.ZIndex = 99

		-- three small dots
		local function dot(ax,ay)
			local d = Instance.new("Frame", rh)
			d.Size = UDim2.new(0,2,0,2)
			d.AnchorPoint = Vector2.new(ax,ay)
			d.Position = UDim2.new(ax,0,ay,0)
			d.BackgroundColor3 = C.textFaint
			d.BorderSizePixel = 0
			d.ZIndex = 100
			corner(d, 2)
			return d
		end
		local dots = { dot(1,1), dot(1,0.5), dot(0.5,1) }

		local resizing, rs, ss
		rh.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
				resizing = true; rs = i.Position; ss = frame.Size
				for _, d in ipairs(dots) do tw(d, T_FAST, { BackgroundColor3 = C.textSub }) end
				i.Changed:Connect(function()
					if i.UserInputState == Enum.UserInputState.End then
						resizing = false
						for _, d in ipairs(dots) do tw(d, T_FAST, { BackgroundColor3 = C.textFaint }) end
					end
				end)
			end
		end)
		rh.MouseEnter:Connect(function()
			for _, d in ipairs(dots) do tw(d, T_FAST, { BackgroundColor3 = C.textSub }) end
		end)
		rh.MouseLeave:Connect(function()
			if not resizing then
				for _, d in ipairs(dots) do tw(d, T_FAST, { BackgroundColor3 = C.textFaint }) end
			end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if resizing and (i.UserInputType == Enum.UserInputType.MouseMovement
				or i.UserInputType == Enum.UserInputType.Touch) then
				local d = i.Position - rs
				frame.Size = UDim2.new(0,
					math.clamp(ss.X.Offset+d.X, mnW, mxW), 0,
					math.clamp(ss.Y.Offset+d.Y, mnH, mxH))
			end
		end)
	end

