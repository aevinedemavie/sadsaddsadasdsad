	local function switchPage(idx)
		for i, pg in pairs(AllPages) do
			if i==idx then
				if ActivePage==pg then return end
				pg.Visible = true; pg.GroupTransparency = 1
				pg.Position = UDim2.new(0,0,0.02,0)
				tw(pg, T_SMOOTH, { Position=UDim2.new(0,0,0,0), GroupTransparency=0 })
				ActivePage = pg
			else
				if pg.Visible then
					task.spawn(function()
						tw(pg, T_FAST, { GroupTransparency=1 })
						task.wait(0.14)
						if AllPages[idx]~=pg then pg.Visible=false end
					end)
				end
			end
		end
	end

