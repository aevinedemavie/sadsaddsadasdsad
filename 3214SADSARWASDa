				titleL.BackgroundTransparency = 1
				titleL.Position = UDim2.new(0,12,0,5)
				titleL.Size = UDim2.new(0.6,0,0,14)

				local valL = Instance.new("TextLabel", fr)
				valL.Font = Enum.Font.GothamBold
				valL.Text = tostring(cfg.Default)
				valL.TextSize = 11
				valL.TextColor3 = C.textSub
				valL.TextXAlignment = Enum.TextXAlignment.Right
				valL.BackgroundTransparency = 1
				valL.AnchorPoint = Vector2.new(1,0)
				valL.Position = UDim2.new(1,-12,0,5)
				valL.Size = UDim2.new(0.3,0,0,14)

				local trkBg = Instance.new("Frame", fr)
				trkBg.Position = UDim2.new(0,12,0,27)
				trkBg.Size = UDim2.new(1,-24,0,3)
				trkBg.BackgroundColor3 = C.track
				trkBg.BorderSizePixel = 0
				corner(trkBg, 2)

				local fill = Instance.new("Frame", trkBg)
				fill.Size = UDim2.new(0.5,0,1,0)
				fill.BackgroundColor3 = Accent
				fill.BorderSizePixel = 0
				corner(fill, 2)

				local knob = Instance.new("Frame", fill)
				knob.AnchorPoint = Vector2.new(0.5,0.5)
				knob.Position = UDim2.new(1,0,0.5,0)
				knob.Size = UDim2.new(0,11,0,11)
				knob.BackgroundColor3 = Color3.new(1,1,1)
				knob.BorderSizePixel = 0
				knob.ZIndex = 3
				corner(knob, 6)

				local dragging = false
				local function rnd(n,f) return math.floor(n/f+0.5)*f end

				function F:Set(val, silent)
					val = math.clamp(rnd(val,cfg.Increment), cfg.Min, cfg.Max)
					F.Value = val
					valL.Text = tostring(val)
					local pct = (val-cfg.Min)/(cfg.Max-cfg.Min)
					tw(fill, T_SMOOTH, { Size=UDim2.new(pct,0,1,0) })
					ConfigData[key] = val
					if not silent then pcall(cfg.Callback, val) end
				end

				trkBg.InputBegan:Connect(function(i)
					if i.UserInputType==Enum.UserInputType.MouseButton1
					or i.UserInputType==Enum.UserInputType.Touch then
						dragging = true
						tw(knob, T_FAST, { Size=UDim2.new(0,13,0,13) })
						local rel = math.clamp((i.Position.X-trkBg.AbsolutePosition.X)/trkBg.AbsoluteSize.X,0,1)
						F:Set(cfg.Min+(cfg.Max-cfg.Min)*rel)
						i.Changed:Connect(function()
							if i.UserInputState==Enum.UserInputState.End then
								dragging = false
								tw(knob, T_FAST, { Size=UDim2.new(0,11,0,11) })
							end
						end)
					end
				end)
				UserInputService.InputChanged:Connect(function(i)
					if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement
						or i.UserInputType==Enum.UserInputType.Touch) then
						local rel = math.clamp((i.Position.X-trkBg.AbsolutePosition.X)/trkBg.AbsoluteSize.X,0,1)
						F:Set(cfg.Min+(cfg.Max-cfg.Min)*rel)
					end
				end)
				F:Set(F.Value, true)
				itemCount += 1; Elements[key] = F; return F
			end

			-- ──────────────────────────────────────────────────────────────────
			-- AddDropdown
			-- ──────────────────────────────────────────────────────────────────
			function Items:AddDropdown(cfg)
				cfg = cfg or {}
				cfg.Title    = cfg.Title    or "Dropdown"
				cfg.Multi    = cfg.Multi    or false
				cfg.Options  = cfg.Options  or {}
				cfg.Default  = cfg.Default  or (cfg.Multi and {} or nil)
				cfg.Callback = cfg.Callback or function() end
				local key = "Dropdown_"..cfg.Title
				if ConfigData[key]~=nil then cfg.Default=ConfigData[key] end
				local F = { Value=cfg.Default, Options=cfg.Options }

				local fr = Instance.new("Frame", IHolder)
				fr.Size = UDim2.new(1,0,0,34)
				fr.BackgroundColor3 = C.surface
				fr.BorderSizePixel = 0
				fr.LayoutOrder = itemCount
				corner(fr, 7)

				local dbtn = Instance.new("TextButton", fr)
				dbtn.Size = UDim2.new(1,0,1,0)
				dbtn.BackgroundTransparency = 1; dbtn.Text = ""

				dbtn.MouseEnter:Connect(function() tw(fr, T_FAST, { BackgroundColor3=C.surfaceHov }) end)
				dbtn.MouseLeave:Connect(function() tw(fr, T_FAST, { BackgroundColor3=C.surface }) end)

				local titleL = Instance.new("TextLabel", fr)
				titleL.Font = Enum.Font.GothamBold
				titleL.Text = cfg.Title
				titleL.TextSize = 12
				titleL.TextColor3 = C.text
				titleL.TextXAlignment = Enum.TextXAlignment.Left
				titleL.BackgroundTransparency = 1
				titleL.Position = UDim2.new(0,12,0,0)
				titleL.Size = UDim2.new(0.44,0,1,0)

				-- value chip
				local chip = Instance.new("Frame", fr)
				chip.AnchorPoint = Vector2.new(1,0.5)
				chip.Position = UDim2.new(1,-8,0.5,0)
				chip.Size = UDim2.new(0,110,0,22)
				chip.BackgroundColor3 = C.inputBg
				chip.BorderSizePixel = 0
				corner(chip, 6)
				stroke(chip, C.line, 1, 0)

				local chipLbl = Instance.new("TextLabel", chip)
				chipLbl.Font = Enum.Font.Gotham
				chipLbl.Text = "None"
				chipLbl.TextSize = 11
				chipLbl.TextColor3 = C.textSub
				chipLbl.TextTruncate = Enum.TextTruncate.AtEnd
				chipLbl.TextXAlignment = Enum.TextXAlignment.Left
				chipLbl.BackgroundTransparency = 1
				chipLbl.Position = UDim2.new(0,7,0,0)
				chipLbl.Size = UDim2.new(1,-20,1,0)

				local arrow = Instance.new("TextLabel", chip)
				arrow.Font = Enum.Font.Gotham
				arrow.Text = "›"
				arrow.TextSize = 14
				arrow.TextColor3 = C.textFaint
				arrow.BackgroundTransparency = 1
				arrow.AnchorPoint = Vector2.new(1,0.5)
				arrow.Position = UDim2.new(1,-4,0.5,0)
				arrow.Size = UDim2.new(0,14,0,14)
				arrow.Rotation = 90

				local function updateChip()
					if cfg.Multi then
						if not F.Value or #F.Value==0 then chipLbl.Text="None"
						else
							local t={}
							for _,v in ipairs(F.Value) do t[#t+1]=tostring(v) end
							chipLbl.Text = table.concat(t,", ")
						end
					else
						chipLbl.Text = F.Value~=nil and tostring(F.Value) or "None"
					end
				end

				function F:_apply()
					ConfigData[key] = F.Value
					updateChip()
					if cfg.Multi then pcall(cfg.Callback, F.Value)
					else pcall(cfg.Callback, F.Value~=nil and tostring(F.Value) or "") end
				end

				dbtn.MouseButton1Click:Connect(function()
					openDropdown(cfg.Title, F.Options, F, cfg.Multi)
				end)

				function F:Clear() F.Value=cfg.Multi and {} or nil; F.Options={}; updateChip() end
				function F:AddOption(opt) table.insert(F.Options,opt) end
				function F:Set(val, silent)
					if cfg.Multi then F.Value=type(val)=="table" and val or {}
					else F.Value=(type(val)=="table" and val[1]) or val end
					F:_apply()
				end
				function F:SetValue(v) self:Set(v) end
				function F:GetValue() return self.Value end
				function F:SetValues(nl, sel)
					F.Options=nl or {}; F:Set(sel or (cfg.Multi and {} or nil))
				end

				updateChip()
				itemCount += 1; Elements[key] = F; return F
			end

			-- ──────────────────────────────────────────────────────────────────
			-- AddInput
			-- ──────────────────────────────────────────────────────────────────
			function Items:AddInput(cfg)
				cfg = cfg or {}
				cfg.Title    = cfg.Title    or "Input"
				cfg.Default  = cfg.Default  or ""
				cfg.Callback = cfg.Callback or function() end
				local key = "Input_"..cfg.Title
				if ConfigData[key]~=nil then cfg.Default=ConfigData[key] end
				local F = { Value=cfg.Default }

				local fr = Instance.new("Frame", IHolder)
				fr.Size = UDim2.new(1,0,0,52)
				fr.BackgroundColor3 = C.surface
				fr.BorderSizePixel = 0
				fr.LayoutOrder = itemCount
				corner(fr, 7)

				local titleL = Instance.new("TextLabel", fr)
				titleL.Font = Enum.Font.GothamBold
				titleL.Text = cfg.Title
				titleL.TextSize = 12
				titleL.TextColor3 = C.text
				titleL.TextXAlignment = Enum.TextXAlignment.Left
				titleL.BackgroundTransparency = 1
				titleL.Position = UDim2.new(0,12,0,7)
				titleL.Size = UDim2.new(1,-18,0,14)

				local ib = Instance.new("TextBox", fr)
				ib.Font = Enum.Font.Gotham
				ib.PlaceholderText = "..."
				ib.PlaceholderColor3 = C.textFaint
				ib.Text = cfg.Default
				ib.TextSize = 11
				ib.TextColor3 = C.textSub
				ib.TextXAlignment = Enum.TextXAlignment.Left
				ib.BackgroundColor3 = C.inputBg
				ib.BorderSizePixel = 0
				ib.Position = UDim2.new(0,10,0,26)
				ib.Size = UDim2.new(1,-20,0,20)
				ib.ClearTextOnFocus = false
				corner(ib, 5)
				local ibS = stroke(ib, C.line, 1, 0)
				pad(ib, 8,0,0,0)

				ib.Focused:Connect(function()
					tw(ibS, T_FAST, { Color=Accent, Transparency=0.4 })
				end)
				ib.FocusLost:Connect(function()
					tw(ibS, T_FAST, { Color=C.line, Transparency=0 })
					F:Set(ib.Text)
				end)

				function F:Set(val, silent)
					F.Value=val; ib.Text=val; ConfigData[key]=val
					if not silent then pcall(cfg.Callback,val) end
				end
				ib:GetPropertyChangedSignal("Text"):Connect(function()
					F.Value=ib.Text; ConfigData[key]=ib.Text
				end)
				F:Set(F.Value, true)
				itemCount += 1; Elements[key] = F; return F
			end

			-- ──────────────────────────────────────────────────────────────────
			-- AddButton
			-- ──────────────────────────────────────────────────────────────────
			function Items:AddButton(cfg)
				cfg = cfg or {}
				cfg.Title       = cfg.Title       or "Button"
				cfg.Callback    = cfg.Callback    or function() end
				cfg.SubTitle    = cfg.SubTitle
				cfg.SubCallback = cfg.SubCallback or function() end

				local fr = Instance.new("Frame", IHolder)
				fr.Size = UDim2.new(1,0,0,34)
				fr.BackgroundColor3 = C.surface
				fr.BorderSizePixel = 0
				fr.LayoutOrder = itemCount
				corner(fr, 7)

				local function makeBtn(txt, x, w)
					local b = Instance.new("TextButton", fr)
					b.Font = Enum.Font.GothamBold
					b.Text = txt
					b.TextSize = 11
					b.TextColor3 = C.textSub
					b.BackgroundColor3 = C.btnSurface
					b.BackgroundTransparency = 0
					b.BorderSizePixel = 0
					b.AutoButtonColor = false
					b.Size = UDim2.new(w,-5,0,26)
					b.Position = UDim2.new(x,4,0,4)
					corner(b, 6)

					b.MouseEnter:Connect(function()
						tw(b, T_FAST, { BackgroundColor3=C.btnHov, TextColor3=C.text })
					end)
					b.MouseLeave:Connect(function()
						tw(b, T_FAST, { BackgroundColor3=C.btnSurface, TextColor3=C.textSub })
					end)
					b.MouseButton1Down:Connect(function()
						tw(b, T_LINEAR, { BackgroundColor3=Accent, TextColor3=Color3.new(0,0,0) })
					end)
					b.MouseButton1Up:Connect(function()
						tw(b, T_FAST, { BackgroundColor3=C.btnHov, TextColor3=C.text })
					end)
					return b
				end

				if cfg.SubTitle then
					local b1 = makeBtn(cfg.Title,    0,   0.5)
					local b2 = makeBtn(cfg.SubTitle, 0.5, 0.5)
					b1.MouseButton1Click:Connect(function() pcall(cfg.Callback) end)
					b2.MouseButton1Click:Connect(function() pcall(cfg.SubCallback) end)
				else
					local b = makeBtn(cfg.Title, 0, 1)
					b.MouseButton1Click:Connect(function() pcall(cfg.Callback) end)
				end
				itemCount += 1
			end

			-- ──────────────────────────────────────────────────────────────────
			-- AddParagraph
			-- ──────────────────────────────────────────────────────────────────
			function Items:AddParagraph(cfg)
				cfg = cfg or {}
				cfg.Title   = cfg.Title   or ""
				cfg.Content = cfg.Content or ""

				local fr = Instance.new("Frame", IHolder)
				fr.Size = UDim2.new(1,0,0,34)
				fr.BackgroundColor3 = C.surface
				fr.BackgroundTransparency = 0.4
				fr.BorderSizePixel = 0
				fr.LayoutOrder = itemCount
				fr.ClipsDescendants = true
				corner(fr, 7)

				-- left accent sliver
				local sliver = Instance.new("Frame", fr)
				sliver.Size = UDim2.new(0,2,0.6,0)
				sliver.Position = UDim2.new(0,0,0.2,0)
				sliver.BackgroundColor3 = Accent
				sliver.BackgroundTransparency = 0.5
				sliver.BorderSizePixel = 0
				corner(sliver, 2)

				local fp = pad(fr,14,10,8,8)
				local fl = list(fr, 3)
				fl.FillDirection = Enum.FillDirection.Vertical
				fl.HorizontalAlignment = Enum.HorizontalAlignment.Left

				local tLbl = Instance.new("TextLabel", fr)
				tLbl.Font = Enum.Font.GothamBold
				tLbl.Text = cfg.Title
				tLbl.TextSize = 12
				tLbl.TextColor3 = C.text
				tLbl.TextXAlignment = Enum.TextXAlignment.Left
				tLbl.TextWrapped = true
				tLbl.BackgroundTransparency = 1
				tLbl.Size = UDim2.new(1,0,0,14)
				tLbl.LayoutOrder = 1
				tLbl.Visible = cfg.Title~=""

				local cLbl = Instance.new("TextLabel", fr)
				cLbl.Font = Enum.Font.Gotham
				cLbl.Text = cfg.Content
				cLbl.TextSize = 11
				cLbl.TextColor3 = C.textSub
				cLbl.TextXAlignment = Enum.TextXAlignment.Left
				cLbl.TextWrapped = true
				cLbl.BackgroundTransparency = 1
				cLbl.Size = UDim2.new(1,0,0,0)
				cLbl.AutomaticSize = Enum.AutomaticSize.Y
				cLbl.LayoutOrder = 2
				cLbl.Visible = cfg.Content~=""

				local function recalc()
					task.defer(function()
						local h = fl.AbsoluteContentSize.Y+16
						tw(fr, T_SMOOTH, { Size=UDim2.new(1,0,0,math.max(h,34)) })
					end)
				end
				recalc()
				fl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(recalc)

				local F = {}
				function F:SetTitle(v)
					v=v or ""; cfg.Title=v; tLbl.Text=v; tLbl.Visible=v~=""; recalc()
				end
				function F:SetContent(v)
					v=v or ""; cfg.Content=v; cLbl.Text=v; cLbl.Visible=v~=""; recalc()
				end
				itemCount += 1; return F
			end

			-- ──────────────────────────────────────────────────────────────────
			-- AddDivider
			-- ──────────────────────────────────────────────────────────────────
			function Items:AddDivider()
				local line = Instance.new("Frame", IHolder)
				line.Size = UDim2.new(1,-16,0,1)
				line.Position = UDim2.new(0,8,0,0)
				line.BackgroundColor3 = C.line
				line.BorderSizePixel = 0
				line.LayoutOrder = itemCount
				corner(line, 1)
				itemCount += 1
			end

			-- ──────────────────────────────────────────────────────────────────
			-- AddSubSection
			-- ──────────────────────────────────────────────────────────────────
			function Items:AddSubSection(title)
				title = title or ""
				local fr = Instance.new("Frame", IHolder)
				fr.Size = UDim2.new(1,0,0,18)
				fr.BackgroundTransparency = 1
				fr.LayoutOrder = itemCount

				local lbl = Instance.new("TextLabel", fr)
				lbl.Font = Enum.Font.GothamBold
				lbl.Text = title:upper()
				lbl.TextSize = 9
				lbl.TextColor3 = C.textFaint
				lbl.TextXAlignment = Enum.TextXAlignment.Left
				lbl.BackgroundTransparency = 1
				lbl.Position = UDim2.new(0,2,0,3)
				lbl.Size = UDim2.new(1,-4,0,12)

				itemCount += 1; return fr
			end

			return Items
		end -- AddSection

		return Sections
	end -- AddTab

	-- ── Config section ────────────────────────────────────────────────────────
	function GuiFunc:AddConfigSection()
		local ct = Tabs:AddTab({ Name="Settings", Icon="settings" })
		local cs = ct:AddSection("Configuration", true)

		local cDrop = cs:AddDropdown({
			Title="Select Config", Options=GetConfigList(),
			Callback=function() end
		})
		local cInput = cs:AddInput({
			Title="Config Name", Default="", Callback=function() end
		})

		cs:AddButton({
			Title="Save", Callback=function()
				local n = cInput.Value
				if SaveConfigAs(n) then
					Notify("Saved: "..n, 2, Color3.fromRGB(100,200,120))
					cDrop:SetValues(GetConfigList(), n)
				else Notify("Failed to save", 2, Color3.fromRGB(200,80,80)) end
			end,
			SubTitle="Load", SubCallback=function()
				local n = cDrop.Value
				if LoadConfig(n) then Notify("Loaded: "..n, 2, Color3.fromRGB(100,200,120))
				else Notify("Failed to load", 2, Color3.fromRGB(200,80,80)) end
			end
		})
		cs:AddButton({
			Title="Delete", Callback=function()
				local n = cDrop.Value
				if DeleteConfig(n) then
					Notify("Deleted: "..n, 2, Color3.fromRGB(200,180,60))
					cDrop:SetValues(GetConfigList(), nil)
				else Notify("Failed", 2, Color3.fromRGB(200,80,80)) end
			end,
			SubTitle="Refresh", SubCallback=function()
				cDrop:SetValues(GetConfigList(), cDrop.Value)
				Notify("Refreshed", 1.5, Accent)
			end
		})

		local als = ct:AddSection("Autoload")
		local alT
		alT = als:AddToggle({
			Title="Enable Autoload",
			Default = GetAutoload()~=nil,
			Callback=function(v)
				if v then
					local n = cDrop.Value
					if n and n~="" then SetAutoload(n); Notify("Autoload: "..n, 2, Accent)
					else if alT then alT:Set(false) end; Notify("Select a config first", 2, Color3.fromRGB(200,80,80)) end
				else ClearAutoload(); Notify("Autoload cleared", 2, Accent) end
			end
		})
	end

	return GuiFunc, Tabs
end

return Orion
