-- ── Helpers ──────────────────────────────────────────────────────────────────
local function stroke(parent, color, thick, alpha)
	local s = Instance.new("UIStroke")
	s.Color           = color
	s.Thickness       = thick or 1
	s.Transparency    = alpha or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent          = parent
	return s
end

local function corner(parent, radius)
	local c = Instance.new("UICorner", parent)
	c.CornerRadius = UDim.new(0, radius or 8)
	return c
end

local function tw(obj, info, props)
	TweenService:Create(obj, info, props):Play()
end

local function pad(parent, l, r, t, b)
	local p        = Instance.new("UIPadding", parent)
	p.PaddingLeft  = UDim.new(0, l or 0)
	p.PaddingRight = UDim.new(0, r or 0)
	p.PaddingTop   = UDim.new(0, t or 0)
	p.PaddingBottom = UDim.new(0, b or 0)
	return p
end

local function list(parent, gap, dir)
	local l          = Instance.new("UIListLayout", parent)
	l.Padding        = UDim.new(0, gap or 0)
	l.SortOrder      = Enum.SortOrder.LayoutOrder
	l.FillDirection  = dir or Enum.FillDirection.Vertical
	return l
end

local function isMobile()
	return UserInputService.TouchEnabled
		and not UserInputService.KeyboardEnabled
		and not UserInputService.MouseEnabled
end

-- ── Config helpers ────────────────────────────────────────────────────────────
function GetConfigList()
	local t = {}
	if isfolder and listfiles and gameFolder then
		for _, fp in pairs(listfiles(gameFolder)) do
			local n = fp:match("([^/\\]+)%.json$")
			if n then t[#t+1] = n end
		end
	end
	return t
end

function GetAutoload()
	if isfile and AutoloadFile and isfile(AutoloadFile) then
		local ok, c = pcall(readfile, AutoloadFile)
		if ok and c and c ~= "" then return c:match("^%s*(.-)%s*$") end
	end
end

function SetAutoload(n)   if writefile and AutoloadFile then writefile(AutoloadFile, n) end end
function ClearAutoload()  if delfile and AutoloadFile and isfile(AutoloadFile) then delfile(AutoloadFile) end end

function SaveConfigAs(n)
	if not n or n == "" then return false end
	if writefile and gameFolder then
		ConfigData._version = CURRENT_VERSION
		writefile(gameFolder.."/"..n..".json", HttpService:JSONEncode(ConfigData))
		CurrentConfigName = n
		return true
	end
	return false
end

function LoadConfig(n)
	if not n or n == "" or not CURRENT_VERSION then return false end
	local fp = gameFolder.."/"..n..".json"
	if isfile and isfile(fp) then
		local ok, r = pcall(function() return HttpService:JSONDecode(readfile(fp)) end)
		if ok and type(r)=="table" and r._version==CURRENT_VERSION then
			ConfigData = r; CurrentConfigName = n; LoadConfigElements(); return true
		end
	end
	return false
end

function DeleteConfig(n)
	if not n or n == "" then return false end
	local fp = gameFolder.."/"..n..".json"
	if delfile and isfile(fp) then
		delfile(fp)
		if GetAutoload()==n then ClearAutoload() end
		return true
	end
	return false
end

function LoadConfigElements()
	for k, el in pairs(Elements) do
		if ConfigData[k] ~= nil and el.Set then pcall(el.Set, el, ConfigData[k], true) end
	end
end

function ResetElements()
	ConfigData = { _version = CURRENT_VERSION }
	for k, el in pairs(Elements) do
		if el.Set then pcall(function()
			if k:match("^Toggle_")   then el:Set(false)
			elseif k:match("^Slider_")   then el:Set(0)
			elseif k:match("^Input_")    then el:Set("")
			elseif k:match("^Dropdown_") then el:Set(type(el.Value)=="table" and {} or nil)
			end
		end) end
	end
end

