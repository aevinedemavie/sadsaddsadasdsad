	local function openDropdown(title, options, dropRef, multi)
		dpLbl.Text = title
		dpSearch.Text = ""
		activeDropRef = dropRef
		for _, c in dpScroll:GetChildren() do if c:IsA("Frame") then c:Destroy() end end

		for i, opt in ipairs(options) do
			local lbl, val
			if type(opt)=="table" and opt.Label then lbl=tostring(opt.Label); val=opt.Value
			else lbl=tostring(opt); val=opt end

			local row = Instance.new("Frame", dpScroll)
			row.Size = UDim2.new(1,0,0,28)
			row.BackgroundColor3 = C.surface
			row.BackgroundTransparency = 1
			row.BorderSizePixel = 0
			row.LayoutOrder = i
			row.ZIndex = 83
			corner(row, 6)
			row:SetAttribute("Val", val)

			local rb = Instance.new("TextButton", row)
			rb.Text = ""; rb.Size = UDim2.new(1,0,1,0)
			rb.BackgroundTransparency = 1; rb.ZIndex = 84

			local rl = Instance.new("TextLabel", row)
			rl.Name = "Label"; rl.Font = Enum.Font.Gotham
			rl.Text = lbl; rl.TextSize = 12
			rl.TextColor3 = C.textSub
			rl.TextXAlignment = Enum.TextXAlignment.Left
			rl.BackgroundTransparency = 1
			rl.Position = UDim2.new(0,10,0,0)
			rl.Size = UDim2.new(1,-28,1,0)
			rl.ZIndex = 83

			local ck = Instance.new("Frame", row)
			ck.Name = "Check"; ck.AnchorPoint = Vector2.new(1,0.5)
			ck.Position = UDim2.new(1,-8,0.5,0)
			ck.Size = UDim2.new(0,7,0,7)
			ck.BackgroundColor3 = Accent
			ck.BorderSizePixel = 0; ck.ZIndex = 83
			corner(ck, 4)

			local isSel = multi and table.find(dropRef.Value, val)~=nil or dropRef.Value==val
			ck.Visible = isSel
			if isSel then
				row.BackgroundTransparency = 0.7
				rl.TextColor3 = C.text
			else
				row.BackgroundTransparency = 1
			end

			rb.MouseEnter:Connect(function()
				local s = multi and table.find(dropRef.Value,val)~=nil or dropRef.Value==val
				tw(row, T_FAST, { BackgroundTransparency = s and 0.6 or 0.82 })
			end)
			rb.MouseLeave:Connect(function()
				local s = multi and table.find(dropRef.Value,val)~=nil or dropRef.Value==val
				tw(row, T_FAST, { BackgroundTransparency = s and 0.7 or 1 })
			end)

			rb.MouseButton1Click:Connect(function()
				if multi then
					local idx = table.find(dropRef.Value, val)
					if idx then table.remove(dropRef.Value, idx) else table.insert(dropRef.Value, val) end
				else
					dropRef.Value = val
				end
				for _, rf in dpScroll:GetChildren() do
					if rf:IsA("Frame") and rf:FindFirstChild("Check") then
						local rv = rf:GetAttribute("Val")
						local s = multi and table.find(dropRef.Value,rv)~=nil or dropRef.Value==rv
						rf.Check.Visible = s
						tw(rf, T_FAST, { BackgroundTransparency = s and 0.7 or 1 })
						if rf:FindFirstChild("Label") then
							tw(rf.Label, T_FAST, { TextColor3 = s and C.text or C.textSub })
						end
					end
				end
				dropRef:_apply()
				if not multi then closeDropdown() end
			end)
		end

		DropBg.Visible = true
		DropBg.BackgroundTransparency = 1
		tw(DropBg, T_SMOOTH, { BackgroundTransparency = 0.5 })

